# --- Python / uv ---
.venv/
__pycache__/
*.pyc
.python-version

# --- 생성물 전부 여기 한 곳으로 (재생성 가능, 용량 큼) ---
# outputs/model/{runs,eval,logs}  ·  outputs/experiments/{runs,plots,logs,results}  ·  outputs/app
# 결론/보고서는 docs/ 에 보존
outputs/

# --- 학습 입력물 (스크립트로 재생성 가능, 용량 큼 · outputs 아님) ---
# datasets: data/ 원본을 YOLO 형식으로 변환한 학습 입력 (yaml이 절대경로 참조 → 이동 금지)
01-model/datasets/
01-model/experiments/datasets/

# --- 모델 가중치 (용량 커서 git 제외, 별도 보관) ---
*.pt
*.onnx
!01-model/weights/.gitkeep
!02-app/models/.gitkeep

# --- PyInstaller 배포 산출물 ---
02-app/build/
02-app/dist/

# --- 데이터 원본 (이미 로컬 확보, git 추적 안 함) ---
data/

# --- OS ---
.DS_Store
